{
  "version": 4,
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (host) Release",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/cmake_build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_FLAGS": "-fpermissive",
        "CMAKE_POLICY_VERSION_MINIMUM": "3.5"
      }
    },
    {
      "name": "default-debug",
      "displayName": "Default (host) Debug",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/cmake_build_debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS": "-fpermissive",
        "CMAKE_POLICY_VERSION_MINIMUM": "3.5"
      }
    },
    {
      "name": "android-arm64",
      "displayName": "Android arm64-v8a Release",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/cmake_build_android_arm64",
      "toolchainFile": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "Android",
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "26",
        "CMAKE_BUILD_TYPE": "Release",
        "LITERT_AUTO_BUILD_TFLITE": "ON",
        "CMAKE_POLICY_VERSION_MINIMUM": "3.5"
      }
    },
    {
      "name": "android-arm64-debug",
      "displayName": "Android arm64-v8a Debug",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/cmake_build_android_arm64_debug",
      "toolchainFile": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "Android",
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "26",
        "CMAKE_BUILD_TYPE": "Debug",
        "LITERT_AUTO_BUILD_TFLITE": "ON",
        "CMAKE_POLICY_VERSION_MINIMUM": "3.5"
      }
    },
    {
      "name": "linux-aarch64-iq8",
      "displayName": "Linux aarch64 (IQ8275)",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/cmake_build_linux_aarch64_8275",
      "toolchainFile": "${sourceDir}/vendors/qualcomm/toolchain/linux_aarch64_iq8275.toolchain.cmake",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "Linux",
        "CMAKE_SYSTEM_PROCESSOR": "aarch64",
        "CMAKE_BUILD_TYPE": "Release",
        "LITERT_AUTO_BUILD_TFLITE": "ON"
      }
    }
  ]
}
