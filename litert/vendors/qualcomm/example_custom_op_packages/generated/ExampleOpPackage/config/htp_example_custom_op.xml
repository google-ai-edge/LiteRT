<OpDefCollection
        PackageName="ExampleOpPackage"
        Domain="aisw"
        Version="1.0"
        UseQHPI="true"
>
    <OpDefList>
        <OpDef>
            <Name>ExampleCustomOp</Name>
            <Description>
                <Content>
                    ExampleCustomOp for testing OP package registration functionality.
                </Content>
            </Description>

            <Input>
                <Name>input</Name>
                <Description>
                    <Content>input activation</Content>
                </Description>
                <Mandatory>true</Mandatory>
                <Datatype>QNN_DATATYPE_FLOAT_32</Datatype>
                <Shape>
                    <Rank>4D</Rank>
                    <Layout>NHWC</Layout>
                    <Text>a tensor of 4 dimension</Text>
                </Shape>
            </Input>

            <Output>
                <Name>output</Name>
                <Description>
                    <Content>output activation</Content>
                </Description>
                <Mandatory>true</Mandatory>
                <Datatype>QNN_DATATYPE_FLOAT_32</Datatype>
                <Shape>
                    <Rank>4D</Rank>
                    <Layout>NHWC</Layout>
                    <Text>a tensor of 4 dimension</Text>
                </Shape>
            </Output>

            <Parameter>
                <Name>CustomInitialData</Name>
                <Description>
                    <Content>Test if we can pass CustomInitialData</Content>
                </Description>
                <Mandatory>true</Mandatory>
                <Datatype>QNN_DATATYPE_UINT_8</Datatype>
                <Shape>
                    <Rank>1D</Rank>
                    <Text>[b], b = size in bytes of the blob</Text>
                </Shape>
            </Parameter>

            <!--This Op is implemented on these Backends-->
            <SupportedBackend>HTP</SupportedBackend>
        </OpDef>

    </OpDefList>

</OpDefCollection>
